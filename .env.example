# Configuration Backend
PORT=5000
NODE_ENV=development

# Base de données
DATABASE_PATH=./database/chatbot.db

# JWT Secret (Générez une clé sécurisée)
JWT_SECRET=changez_moi_avec_une_clé_secrète_très_sécurisée_minimum_32_caractères
JWT_EXPIRE=7d

# Admin par défaut
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPassword123!

# Email Configuration (Optionnel - pour envoyer des emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_mot_de_passe_app
SMTP_FROM=noreply@example.com

# Paiement - PayPal
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# Paiement - Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# URLs publiques
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Configuration des ebooks
EBOOK_1_NAME=Marketing Digital de A à Z
EBOOK_1_PRICE=29.99
EBOOK_1_DESCRIPTION=Apprenez les stratégies de marketing digital les plus efficaces
EBOOK_1_DOWNLOAD_URL=

EBOOK_2_NAME=Faire plus de 100 ventes en moins d'un mois
EBOOK_2_PRICE=39.99
EBOOK_2_DESCRIPTION=Stratégies éprouvées pour augmenter rapidement vos ventes
EBOOK_2_DOWNLOAD_URL=
